{
  "name": "@repogotchi/contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "JSON Schemas and generated types for RepoGotchi pet.json + state.json.",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/pet.json": "./schemas/pet.schema.json",
    "./schemas/state.json": "./schemas/state.schema.json"
  },
  "files": ["src", "schemas", "generated"],
  "scripts": {
    "codegen": "tsx scripts/codegen.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "quicktype": "^23.0.171",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5"
  }
}
